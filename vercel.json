{
  "buildCommand": "echo 'No build required for static site'",
  "outputDirectory": ".",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/music.mp3",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/img/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
